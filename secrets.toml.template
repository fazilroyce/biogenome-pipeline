# .streamlit/secrets.toml
# Add this file to your GitHub repo's Streamlit Cloud secrets (NOT committed to GitHub)
# In Streamlit Cloud: Settings → Secrets → paste this

[snowflake]
account  = "YOUR_ACCOUNT_IDENTIFIER"   # e.g. abc12345.ap-south-1
user     = "YOUR_SNOWFLAKE_USERNAME"
password = "YOUR_SNOWFLAKE_PASSWORD"
